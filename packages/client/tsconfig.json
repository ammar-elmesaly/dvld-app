{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "composite": true, // Required for the -b flag
    "declaration": true,
    "skipLibCheck": true,
    // "strict": true,
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true
  },
  "include": ["src", "electron"],
  "references": [{ "path": "../shared" }]
}