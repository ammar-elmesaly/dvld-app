{
  "name": "@dvld/server",
  "version": "1.0.0",
  "description": "Server for DVLD (Drivers and Vehicles License Department)",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "nodemon --exec node --env-file=.env --import tsx src/index.ts",
    "start:dev": "TSX_TSCONFIG_PATH=tsconfig.json nodemon --watch 'src/**/*' --watch '../shared/src/**/*' --ext ts --exec 'node --env-file=.env --import tsx src/index.ts'",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "DVLD",
    "Electron",
    "License Management"
  ],
  "author": {
    "name": "Ammar Elmesaly",
    "email": "ammar-elmesaly@proton.me"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.16.0",
    "express-session": "^1.18.2",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@dvld/shared": "*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28"
  }
}
