{
  "name": "dvld",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf packages/*/dist",
    "watch": "tsc -b -w",
    "server": "npm run start -w @dvld/server",
    "client": "npm run start:dev -w @dvld/client"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}